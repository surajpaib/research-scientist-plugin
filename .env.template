# Research Scientist Plugin - API Keys Configuration
#
# Copy this file to .env and fill in your keys:
#   cp .env.template .env
#
# All keys are OPTIONAL - the plugin works without them.
# API keys provide higher rate limits and better service.

# =============================================================================
# PubMed / NCBI (National Center for Biotechnology Information)
# =============================================================================
# Get a free API key at: https://www.ncbi.nlm.nih.gov/account/settings/
#
# Without key: 3 requests/second
# With key: 10 requests/second
#
NCBI_API_KEY=

# =============================================================================
# CrossRef (DOI metadata lookup)
# =============================================================================
# No registration needed - just provide your email
# This puts you in the "polite pool" for higher rate limits
#
# Without email: ~50 requests/second (shared pool, may be throttled)
# With email: Higher priority in polite pool
#
# More info: https://www.crossref.org/documentation/retrieve-metadata/rest-api/
#
CROSSREF_EMAIL=

# =============================================================================
# Semantic Scholar (optional, for enhanced paper metadata)
# =============================================================================
# Get a free API key at: https://www.semanticscholar.org/product/api
#
# Without key: 100 requests/5 minutes
# With key: 1000 requests/5 minutes
#
SEMANTIC_SCHOLAR_API_KEY=

# =============================================================================
# Zotero (bibliography management)
# =============================================================================
# Required only if using Zotero integration with MCP server
#
# Get your API key at: https://www.zotero.org/settings/keys
# Find your User ID at: https://www.zotero.org/settings/keys (top of page)
#
# Note: You also need Zotero desktop + Better BibTeX plugin installed
#
ZOTERO_API_KEY=
ZOTERO_USER_ID=
