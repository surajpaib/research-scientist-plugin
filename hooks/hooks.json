{
  "PreToolUse": [
    {
      "matcher": "Read",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/plugins/research-scientist/scripts/phi_guard.sh \"$TOOL_INPUT\"",
          "timeout": 3000,
          "onFailure": "block",
          "description": "PHI Guard: Blocks access to protected health information (configure patterns in .claude/phi_config.yaml)"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/plugins/research-scientist/scripts/validate_output.sh \"$TOOL_INPUT\"",
          "timeout": 5000,
          "description": "PHI Validation: Scans newly written files for potential PHI leakage"
        }
      ]
    }
  ]
}
